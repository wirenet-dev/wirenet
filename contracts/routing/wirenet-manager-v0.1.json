      "trigger": "WireNet Manager is installed, missing, unhealthy, or being repaired.",
      "reads": ["installed plugin seed", "approved project roots", "existing Manager when repairing"],
      "writes": ["content-only Manager", ".wirenet/manager.json", ".wirenet/project-bindings.json", "optional global managed blocks"],
      "approval": "dry-run first; approval before apply, project-root inspection, or global guidance",
      "description": "Bootstrap content separately from behavior, discover only approved roots, and never overwrite personalized files during repair.",
