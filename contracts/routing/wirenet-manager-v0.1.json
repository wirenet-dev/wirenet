    {
      "id": "project-state-routing",
      "trigger": "A meaningful durable project transition would otherwise make a future task resume incorrectly.",
      "reads": ["README.md", "AGENTS.md", "optional concepts when present and relevant", "log.md only when chronology matters", "smallest useful external evidence"],
      "writes": ["smallest canonical state diff", "optional typed concept when it earns a distinct purpose", "optional linked log.md entry when sparse chronology adds value"],
      "approval": "preview and explicit approval unless the exact update was already approved",
      "description": "Keep the open packet useful without forcing empty documents or activity-log churn; route each durable change to the clearest canonical concept.",
      "evidence": ["plugins/wirenet-manager/skills/wirenet-manager-sync/SKILL.md", "plugins/wirenet-manager/skills/wirenet-manager-sync/references/update-contract.md"]
    },
    {
      "id": "project-create",
      "trigger": "An approved external workspace is classified as a durable project.",
      "reads": ["projects/index.md", ".wirenet/project-bindings.json", "approved workspace path"],
      "writes": ["README.md", "AGENTS.md", "projects/index.md entry", "local binding", "requested optional concepts"],
      "approval": "dry-run preview then explicit apply approval",
      "description": "Create the portable open packet core and bind it to external implementation work without copying that work into Manager.",
      "evidence": ["plugins/wirenet-manager/scripts/create_project_pack.py", "plugins/wirenet-manager/skills/wirenet-manager-bootstrap/SKILL.md"]
    },
    {
