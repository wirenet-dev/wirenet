{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wirenet.dev/schemas/wirenet-bindings-v1.json",
  "title": "wirenet Manager workspace bindings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bindings", "ignored"],
  "properties": {
    "schema_version": { "const": "wirenet-bindings/v1" },
    "bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9._-]*$" }
    },
    "ignored": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
