#!/usr/bin/env python3
"""Lean local control plane for the WireNet system.

Commands:
  wirenet status   Report the four element instances, git state, and bindings.
  wirenet doctor   Run the read-only Manager doctor from this repository.

Canonical reference: Base governance concept "WireNet system architecture".
"""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
HOME = Path.home()

ELEMENTS = {
    "Manager": HOME / "Manager",
    "Shelf": HOME / "Developer" / "shelf",
    "Base": HOME / "Data" / "base",
    "Product": REPO,
}


def git(path: Path, *args: str) -> str | None:
    result = subprocess.run(
        ["git", "-C", str(path), *args],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def describe(label: str, path: Path) -> None:
    if not path.exists():
        print(f"{label}: {path} — MISSING")
        return
    branch = git(path, "branch", "--show-current")
    if branch is None:
        print(f"{label}: {path} — no git")
        return
    dirty = git(path, "status", "--porcelain")
    state = "dirty" if dirty else "clean"
    print(f"{label}: {path} — {branch or '(detached)'}, {state}")


def check_bindings() -> int:
    bindings = ELEMENTS["Manager"] / ".wirenet" / "workspace-bindings.json"
    if not bindings.is_file():
        print(f"bindings: {bindings} — MISSING")
        return 1
    data = json.loads(bindings.read_text())
    broken = 0
    for kind in ("projects", "experiments"):
        for entry in data.get(kind, []):
            path = Path(entry["path"])
            if not path.exists():
                ident = entry.get("project_id") or entry.get("experiment_id")
                print(f"binding {ident}: {path} — MISSING")
                broken += 1
    total = sum(len(data.get(k, [])) for k in ("projects", "experiments"))
    print(f"bindings: {total - broken}/{total} resolve")
    return 1 if broken else 0


def status() -> int:
    print("WireNet system status")
    for label, path in ELEMENTS.items():
        describe(label, path)
    return check_bindings()


def doctor(args: list[str]) -> int:
    script = REPO / "scripts" / "manager_doctor.py"
    return subprocess.run([sys.executable, str(script), *args]).returncode


def main(argv: list[str]) -> int:
    command = argv[0] if argv else "status"
    if command == "status":
        return status()
    if command == "doctor":
        return doctor(argv[1:])
    print(__doc__.strip(), file=sys.stderr)
    return 0 if command in {"-h", "--help", "help"} else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
