{
  "schema_version": "wirenet-lifecycle-contract/v0.2",
  "project": {
    "identity_key": "project_id",
    "collection": "projects",
    "statuses": ["active", "waiting", "blocked", "completed", "archived"],
    "transitions": {
      "active": ["waiting", "blocked", "completed", "archived"],
      "waiting": ["active", "blocked", "completed", "archived"],
      "blocked": ["active", "waiting", "completed", "archived"],
      "completed": ["active", "archived"],
      "archived": ["active"]
    },
    "archive_rule": "Archive only when no open next move or waiting handoff remains and durable results have been retained."
  },
  "experiment": {
    "identity_key": "experiment_id",
    "collection": "experiments",
    "statuses": ["active", "concluded", "promoted", "archived"],
    "transitions": {
      "active": ["concluded", "promoted", "archived"],
      "concluded": ["active", "promoted", "archived"],
      "promoted": [],
      "archived": ["active", "promoted"]
    },
    "promotion_rule": "Promote when the spike becomes a durable multi-session workstream; preserve the Experiment Pack as origin evidence."
  },
  "worklog": {
    "path": "projects/<slug>/WORKLOG.md",
    "owner": "ultragoal",
    "required_type": "Goal Worklog",
    "implicit_activation_allowed": false
  }
}
